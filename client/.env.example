# ─── ENVIRONMENT VARIABLES ──────────────────────────────────────────

# Development: Leave blank to use http://localhost:5000
# Production: set this to your Render backend URL (no trailing slash)
# Example: https://mern-chat-server.onrender.com
VITE_API_URL=https://your-render-app.onrender.com

# ─── BUILD SETTINGS ─────────────────────────────────────────────────
# Vite automatically handles these, but you can override:
# VITE_APP_NAME=ChatApp
